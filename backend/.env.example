# PostgreSQL connection string (Supabase / local postgres)
DATABASE_URL=postgres://user:password@localhost:5432/vehicle_tracker?sslmode=disable

# HS256 secret — use a long random string in production
# Generate one with: openssl rand -hex 32
JWT_SECRET=change-me-use-a-long-random-secret

# HTTP port (optional, defaults to 8081)
PORT=8081

# Comma-separated allowed CORS origins (empty = allow all, only for local dev)
# Example: https://your-app.vercel.app,http://localhost:5174
ALLOWED_ORIGINS=
